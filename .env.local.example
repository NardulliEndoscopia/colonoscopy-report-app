# ─────────────────────────────────────────────
# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA subas .env.local a GitHub.
# En Vercel, añade estas variables en Settings → Environment Variables.
# ─────────────────────────────────────────────

# Anthropic API Key (obligatorio)
# Obténla en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Contraseña del panel de administración (obligatorio)
ADMIN_PASSWORD=elige_una_contraseña_segura

# Configuración del médico en JSON (opcional, dejar {} si no se usa)
NEXT_PUBLIC_DOCTOR_CONFIG={}

# Vercel KV — se genera automáticamente al añadir KV Storage en Vercel
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Vercel Blob — se genera automáticamente al añadir Blob Storage en Vercel
# BLOB_READ_WRITE_TOKEN=
